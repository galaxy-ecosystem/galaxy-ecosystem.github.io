---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PublicationItem from '../components/PublicationItem.astro';
import { BookOpen } from 'lucide-react';

const papers = (await getCollection('publications'))
  .filter(p => p.data.type === 'paper')
  .sort((a, b) => b.data.year - a.data.year);
---

<Layout title="Achievements">
  <div class="max-w-7xl mx-auto px-4 py-12 sm:py-20">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-4" data-i18n-key="achievements.title">Research Achievements</h1>
      <p class="text-lg text-gray-600" data-i18n-key="achievements.subtitle">
        A comprehensive collection of our academic publications.
      </p>
    </div>

    <div class="space-y-24">
      <section id="papers" class="scroll-mt-24">
        <div class="flex items-center gap-3 mb-8">
          <BookOpen className="w-8 h-8 text-blue-600" />
          <h2 class="text-3xl font-bold text-gray-900" data-i18n-key="achievements.papers">Published Papers</h2>
        </div>
        <div class="grid gap-6">
          {papers.map(paper => <PublicationItem entry={paper} />)}
          {papers.length === 0 && <p class="text-gray-500 italic" data-i18n-key="achievements.noPapers">No papers listed yet.</p>}
        </div>
      </section>
    </div>
  </div>
</Layout>